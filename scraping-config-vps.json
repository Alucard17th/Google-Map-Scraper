{
  "scrapingConfig": [
    {
      "businessType": "plombier",
      "regions": ["Marseille"],
      "maxResults": 5,
      "enabled": true
    }
  ],
  "safetySettings": {
    "dailyRequestLimit": 25,
    "minDelayBetweenRequests": 8000,
    "maxDelayBetweenRequests": 15000,
    "minDelayBetweenRegions": 20000,
    "maxDelayBetweenRegions": 45000,
    "minDelayBetweenBusinessTypes": 60000,
    "maxDelayBetweenBusinessTypes": 120000,
    "maxScrollsPerSearch": 2,
    "headless": true,
    "randomBreakInterval": 8,
    "randomBreakDuration": 60000
  },
  "schedule": {
    "cronExpression": "0 3 * * *",
    "timezone": "Europe/Paris",
    "enabled": true
  },
  "output": {
    "format": "json",
    "directory": "Output",
    "includeTimestamp": true
  },
  "vps": {
    "autoRestartOnError": true,
    "maxRetries": 3,
    "errorNotificationEmail": "",
    "backupEnabled": true,
    "backupInterval": "daily"
  }
}
